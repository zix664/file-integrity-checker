        if file not in current_hashes:
            print(f"DELETED: {file}")

        elif saved_hases[file] != current_hashes[file]:
            print(f"Moved:{file}")
    for file in current_hashes:
        if file not in saved_hashes:
            print(f"New File: { file}")

